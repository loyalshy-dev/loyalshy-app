// ─────────────────────────────────────────────────────────────
// Loyalshy — Digital Wallet Pass Platform
// Prisma v7 schema — PostgreSQL 18 with uuidv7()
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  USER          @map("user")
  ADMIN_SUPPORT @map("admin_support")
  ADMIN_BILLING @map("admin_billing")
  ADMIN_OPS     @map("admin_ops")
  SUPER_ADMIN   @map("super_admin")

  @@map("user_role")
}

enum AdminAction {
  USER_BANNED              @map("user_banned")
  USER_UNBANNED            @map("user_unbanned")
  USER_ROLE_CHANGED        @map("user_role_changed")
  USER_SESSIONS_REVOKED    @map("user_sessions_revoked")
  USER_IMPERSONATED        @map("user_impersonated")
  USER_IMPERSONATION_ENDED @map("user_impersonation_ended")
  USER_DATA_EXPORTED       @map("user_data_exported")
  USER_DELETED             @map("user_deleted")
  ORG_PLAN_CHANGED         @map("org_plan_changed")
  ORG_STATUS_CHANGED       @map("org_status_changed")
  ORG_DELETED              @map("org_deleted")
  CONTACTS_PURGED          @map("contacts_purged")
  BULK_BAN                 @map("bulk_ban")
  BULK_STATUS_CHANGE       @map("bulk_status_change")
  BULK_EXPORT              @map("bulk_export")

  @@map("admin_action")
}

enum SubscriptionStatus {
  TRIALING @map("trialing")
  ACTIVE   @map("active")
  PAST_DUE @map("past_due")
  CANCELED @map("canceled")

  @@map("subscription_status")
}

enum Plan {
  FREE       @map("free")
  STARTER    @map("starter")
  GROWTH     @map("growth")
  SCALE      @map("scale")
  ENTERPRISE @map("enterprise")

  @@map("plan")
}

enum PassType {
  STAMP_CARD @map("stamp_card")
  COUPON     @map("coupon")

  @@map("pass_type")
}

enum TemplateStatus {
  DRAFT    @map("draft")
  ACTIVE   @map("active")
  ARCHIVED @map("archived")

  @@map("template_status")
}

enum PassInstanceStatus {
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  SUSPENDED @map("suspended")
  EXPIRED   @map("expired")
  REVOKED   @map("revoked")

  @@map("pass_instance_status")
}

enum WalletProvider {
  APPLE  @map("apple")
  GOOGLE @map("google")
  NONE   @map("none")

  @@map("wallet_provider")
}

enum InteractionType {
  STAMP           @map("stamp")
  COUPON_REDEEM   @map("coupon_redeem")
  STATUS_CHANGE   @map("status_change")
  REWARD_EARNED   @map("reward_earned")
  REWARD_REDEEMED @map("reward_redeemed")
  NOTE            @map("note")

  @@map("interaction_type")
}

enum RewardStatus {
  AVAILABLE @map("available")
  REDEEMED  @map("redeemed")
  EXPIRED   @map("expired")

  @@map("reward_status")
}

enum WalletPassAction {
  CREATED     @map("created")
  UPDATED     @map("updated")
  PUSH_SENT   @map("push_sent")
  PUSH_FAILED @map("push_failed")

  @@map("wallet_pass_action")
}

enum StaffRole {
  OWNER @map("owner")
  STAFF @map("staff")

  @@map("staff_role")
}

// ─── Design Enums ────────────────────────────────────────────

enum PatternStyle {
  NONE            @map("none")
  DOTS            @map("dots")
  WAVES           @map("waves")
  GEOMETRIC       @map("geometric")
  CHEVRON         @map("chevron")
  CROSSHATCH      @map("crosshatch")
  DIAMONDS        @map("diamonds")
  CONFETTI        @map("confetti")
  SOLID_PRIMARY   @map("solid_primary")
  SOLID_SECONDARY @map("solid_secondary")
  STAMP_GRID      @map("stamp_grid")

  @@map("pattern_style")
}

enum ProgressStyle {
  NUMBERS    @map("numbers")
  CIRCLES    @map("circles")
  SQUARES    @map("squares")
  STARS      @map("stars")
  STAMPS     @map("stamps")
  PERCENTAGE @map("percentage")
  REMAINING  @map("remaining")

  @@map("progress_style")
}

enum FontFamily {
  SANS    @map("sans")
  SERIF   @map("serif")
  ROUNDED @map("rounded")
  MONO    @map("mono")

  @@map("font_family")
}

enum LabelFormat {
  UPPERCASE  @map("uppercase")
  TITLE_CASE @map("title_case")
  LOWERCASE  @map("lowercase")

  @@map("label_format")
}

enum DesignCardType {
  STAMP  @map("stamp")
  COUPON @map("coupon")

  @@map("design_card_type")
}

// ─── Better Auth Core Tables ─────────────────────────────────
// These 4 models MUST match Better Auth's expected schema.
// Custom fields (role) are added via additionalFields in auth config.

model User {
  id            String    @id @default(dbgenerated("uuidv7()::text"))
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(USER)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions              Session[]
  accounts              Account[]
  members               Member[]
  invitations           Invitation[]
  performedInteractions Interaction[]        @relation("PerformedBy")
  redeemedRewards       Reward[]             @relation("RedeemedBy")
  adminAuditLogs        AdminAuditLog[]      @relation("AdminAuditLogs")
  devicePairingTokens   DevicePairingToken[] @relation("DevicePairingTokens")

  @@map("user")
}

model Session {
  id                   String   @id @default(dbgenerated("uuidv7()::text"))
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("uuidv7()::text"))
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id @default(dbgenerated("uuidv7()::text"))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Better Auth Organization Plugin Tables ──────────────────
// Organization now absorbs Restaurant fields (billing, branding).

model Organization {
  id        String   @id @default(dbgenerated("uuidv7()::text"))
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  // Billing (absorbed from Restaurant)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(STARTER)
  trialEndsAt          DateTime?

  // Branding (absorbed from Restaurant)
  logoApple      String?
  logoGoogle     String?
  brandColor     String?
  secondaryColor String?
  address        String?
  phone          String?
  website        String?
  timezone       String  @default("UTC")
  settings       Json    @default("{}")

  members             Member[]
  invitations         Invitation[]
  passTemplates       PassTemplate[]
  contacts            Contact[]
  interactions        Interaction[]
  rewards             Reward[]
  staffInvitations    StaffInvitation[]
  analyticsSnapshots  AnalyticsSnapshot[]
  devicePairingTokens DevicePairingToken[]

  @@map("organization")
}

model Member {
  id             String   @id @default(dbgenerated("uuidv7()::text"))
  userId         String
  organizationId String
  role           String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(dbgenerated("uuidv7()::text"))
  email          String
  inviterId      String
  organizationId String
  role           String
  status         String   @default("pending")
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("invitation")
}

// ─── Application Models ──────────────────────────────────────

model PassTemplate {
  id                 String         @id @default(dbgenerated("uuidv7()::text"))
  organizationId     String
  name               String
  description        String?        @db.Text
  passType           PassType
  status             TemplateStatus @default(DRAFT)
  startsAt           DateTime       @default(now())
  endsAt             DateTime?
  termsAndConditions String?        @db.Text
  config             Json           @default("{}")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  passInstances PassInstance[]
  passDesign    PassDesign?
  rewards       Reward[]
  interactions  Interaction[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, passType])
  @@map("pass_template")
}

model PassInstance {
  id                     String             @id @default(dbgenerated("uuidv7()::text"))
  contactId              String
  passTemplateId         String
  status                 PassInstanceStatus @default(ACTIVE)
  walletProvider         WalletProvider     @default(NONE)
  walletPassId           String?            @unique
  walletPassSerialNumber String?            @unique
  data                   Json               @default("{}")
  issuedAt               DateTime           @default(now())
  expiresAt              DateTime?
  suspendedAt            DateTime?
  revokedAt              DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  contact             Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  passTemplate        PassTemplate         @relation(fields: [passTemplateId], references: [id], onDelete: Cascade)
  interactions        Interaction[]
  rewards             Reward[]
  walletPassLogs      WalletPassLog[]
  deviceRegistrations DeviceRegistration[]

  @@unique([contactId, passTemplateId])
  @@index([contactId])
  @@index([passTemplateId])
  @@index([walletPassSerialNumber])
  @@index([status])
  @@index([passTemplateId, status])
  @@map("pass_instance")
}

model Contact {
  id                String    @id @default(dbgenerated("uuidv7()::text"))
  organizationId    String
  fullName          String
  email             String?
  phone             String?
  memberNumber      Int
  totalInteractions Int       @default(0)
  lastInteractionAt DateTime?
  metadata          Json      @default("{}")
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  passInstances PassInstance[]
  interactions  Interaction[]
  rewards       Reward[]

  @@unique([organizationId, email])
  @@unique([organizationId, phone])
  @@unique([organizationId, memberNumber])
  @@index([organizationId, deletedAt])
  @@index([organizationId, totalInteractions])
  @@index([email])
  @@map("contact")
}

model Interaction {
  id             String          @id @default(dbgenerated("uuidv7()::text"))
  contactId      String
  organizationId String
  passTemplateId String
  passInstanceId String?
  performedById  String?
  type           InteractionType
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now())

  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  passTemplate PassTemplate  @relation(fields: [passTemplateId], references: [id], onDelete: Cascade)
  passInstance PassInstance? @relation(fields: [passInstanceId], references: [id], onDelete: SetNull)
  performedBy  User?         @relation("PerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, type])
  @@index([passInstanceId])
  @@index([contactId, createdAt])
  @@index([passTemplateId, createdAt])
  @@map("interaction")
}

model Reward {
  id             String       @id @default(dbgenerated("uuidv7()::text"))
  contactId      String
  organizationId String
  passTemplateId String
  passInstanceId String?
  status         RewardStatus @default(AVAILABLE)
  earnedAt       DateTime     @default(now())
  redeemedAt     DateTime?
  expiresAt      DateTime
  redeemedById   String?
  description    String?
  revealedAt     DateTime?

  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  passTemplate PassTemplate  @relation(fields: [passTemplateId], references: [id], onDelete: Cascade)
  passInstance PassInstance? @relation(fields: [passInstanceId], references: [id], onDelete: SetNull)
  redeemedBy   User?         @relation("RedeemedBy", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([passInstanceId])
  @@index([status])
  @@index([organizationId, status])
  @@index([organizationId, expiresAt])
  @@index([organizationId, status, redeemedAt])
  @@index([passTemplateId, status])
  @@map("reward")
}

model PassDesign {
  id                   String         @id @default(dbgenerated("uuidv7()::text"))
  passTemplateId       String         @unique
  cardType             DesignCardType @default(STAMP)
  showStrip            Boolean        @default(true) @map("show_strip")
  primaryColor         String?
  secondaryColor       String?
  textColor            String?
  stripImageUrl        String?
  stripImageApple      String?
  stripImageGoogle     String?
  patternStyle         PatternStyle   @default(NONE)
  progressStyle        ProgressStyle  @default(NUMBERS)
  fontFamily           FontFamily     @default(SANS)
  labelFormat          LabelFormat    @default(UPPERCASE)
  customProgressLabel  String?        @db.VarChar(30)
  generatedStripApple  String?
  generatedStripGoogle String?
  templateId           String?        @db.VarChar(50)
  palettePreset        String?
  businessHours        String?        @db.Text
  mapAddress           String?
  mapLatitude          Float?
  mapLongitude         Float?
  socialLinks          Json           @default("{}")
  customMessage        String?        @db.Text
  logoUrl              String?        @map("logo_url")
  logoAppleUrl         String?        @map("logo_apple_url")
  logoGoogleUrl        String?        @map("logo_google_url")
  designHash           String         @default("")
  editorConfig         Json           @default("{}")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  passTemplate PassTemplate @relation(fields: [passTemplateId], references: [id], onDelete: Cascade)

  @@map("pass_design")
}

model WalletPassLog {
  id             String           @id @default(dbgenerated("uuidv7()::text"))
  passInstanceId String?
  contactId      String?
  action         WalletPassAction
  details        Json             @default("{}")
  createdAt      DateTime         @default(now())

  passInstance PassInstance? @relation(fields: [passInstanceId], references: [id], onDelete: Cascade)

  @@index([passInstanceId])
  @@map("wallet_pass_log")
}

model StaffInvitation {
  id             String    @id @default(dbgenerated("uuidv7()::text"))
  organizationId String
  email          String
  role           StaffRole
  token          String    @unique
  expiresAt      DateTime
  accepted       Boolean   @default(false)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("staff_invitation")
}

model DeviceRegistration {
  id                      String   @id @default(dbgenerated("uuidv7()::text"))
  deviceLibraryIdentifier String
  pushToken               String
  serialNumber            String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  passInstance PassInstance @relation(fields: [serialNumber], references: [walletPassSerialNumber], onDelete: Cascade)

  @@unique([deviceLibraryIdentifier, serialNumber])
  @@index([serialNumber])
  @@map("device_registration")
}

model WebhookEvent {
  id            String   @id @default(dbgenerated("uuidv7()::text"))
  stripeEventId String   @unique
  eventType     String
  processedAt   DateTime @default(now())

  @@index([processedAt])
  @@map("webhook_event")
}

model AnalyticsSnapshot {
  id                String   @id @default(dbgenerated("uuidv7()::text"))
  organizationId    String
  date              DateTime @db.Date
  totalContacts     Int      @default(0)
  newContacts       Int      @default(0)
  totalInteractions Int      @default(0)
  rewardsEarned     Int      @default(0)
  rewardsRedeemed   Int      @default(0)
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId, date])
  @@map("analytics_snapshot")
}

// ─── Admin Audit Log ──────────────────────────────────────────

model AdminAuditLog {
  id          String      @id @default(dbgenerated("uuidv7()::text"))
  adminId     String
  action      AdminAction
  targetType  String
  targetId    String
  targetLabel String?
  metadata    Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  reason      String?     @db.Text
  createdAt   DateTime    @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("admin_audit_log")
}

// ─── Device Pairing Token (mobile app QR login) ───────────────

model DevicePairingToken {
  id              String    @id @default(dbgenerated("uuidv7()::text"))
  organizationId  String
  createdByUserId String
  token           String    @unique
  expiresAt       DateTime
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User         @relation("DevicePairingTokens", fields: [createdByUserId], references: [id])

  @@index([organizationId])
  @@map("device_pairing_token")
}
