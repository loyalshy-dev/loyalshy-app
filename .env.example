# ===========================================
# Loyalshy — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Neon Database ---
DATABASE_URL="postgresql://user:pass@ep-xxx-123.eu-central-1.aws.neon.tech/loyalshy?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx-123.eu-central-1.aws.neon.tech/loyalshy?sslmode=require"

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL="https://eu1-abc-12345.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Better Auth ---
BETTER_AUTH_SECRET="your-random-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- Super Admin (auto-promoted on registration) ---
SUPER_ADMIN_EMAIL=""

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""                        # Web client ID (used by webapp + token verification)
GOOGLE_CLIENT_SECRET=""                    # Web client secret (used by webapp OAuth flow)
GOOGLE_CLIENT_ID_IOS=""                    # iOS client ID (for staff app Google login verification)
GOOGLE_CLIENT_ID_ANDROID=""                # Android client ID (for staff app Google login verification)

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Trigger.dev ---
TRIGGER_SECRET_KEY=""

# --- Resend (Transactional Email) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- Cloudflare R2 (File Uploads) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="loyalshy"
R2_PUBLIC_URL=""

# --- Apple Wallet (Phase 3) ---
APPLE_PASS_TYPE_IDENTIFIER="pass.com.yourcompany.loyalshy"
APPLE_TEAM_IDENTIFIER=""
APPLE_PASS_CERTIFICATE=""      # Base64-encoded .pem signer certificate
APPLE_PASS_KEY=""              # Base64-encoded .pem signer key
APPLE_PASS_KEY_PASSPHRASE=""   # Passphrase for the signer key
APPLE_WWDR_CERTIFICATE=""      # Base64-encoded Apple WWDR G4 certificate

# --- Google Wallet (Phase 3) ---
GOOGLE_WALLET_ISSUER_ID=""                # Issuer ID from Google Pay & Wallet Console
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=""      # Full service account JSON key (or base64-encoded)

# --- Google Maps Api Key ----
GOOGLE_MAPS_API_KEY=""

NEXT_PUBLIC_DEMO_JOIN_URL=""